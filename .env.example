ATHENA_FUND_API_PORT=8081
ATHENA_FUND_WEB_PORT=5173
ATHENA_FUND_POSTGRES_PORT=5433
ATHENA_FUND_REDIS_PORT=6380
ATHENA_BASE_URL=http://host.docker.internal:8080
ATHENA_FUND_LOCAL_AUTH_SUBJECT=demo-user
# Set a local-only value here and inject the matching secret into Athena after Super-Sky/Athena#24 lands.
ATHENA_FUND_REMOTE_TOOL_TOKEN=
ATHENA_REPO=../Athena-remote-tools
ATHENA_DUAL_API_PORT=8080
ATHENA_FAKE_MODEL_PORT=18083
ATHENA_FUND_PROVIDER=mock
ATHENA_FUND_CSV_PATH=/app/examples/market-data-sample.csv
POSTGRES_USER=athena_fund
POSTGRES_PASSWORD=athena_fund
POSTGRES_DB=athena_fund
DATABASE_URL=postgres://athena_fund:athena_fund@postgres:5432/athena_fund?sslmode=disable
REDIS_URL=redis://redis:6379/0
