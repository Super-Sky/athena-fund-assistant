FROM golang:1.23-alpine AS build

WORKDIR /src
COPY go.mod ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/athena-fund-api ./cmd/api

FROM alpine:3.20

RUN adduser -D -g '' appuser
USER appuser

COPY --from=build /out/athena-fund-api /usr/local/bin/athena-fund-api

ENV ATHENA_FUND_API_ADDR=:8081
EXPOSE 8081

ENTRYPOINT ["athena-fund-api"]
